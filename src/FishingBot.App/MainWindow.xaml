<Window x:Class="FishingBot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FishingBot" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Start DetectOnly" Width="140" Margin="0,0,8,0" />
            <Button Content="Start Active" Width="120" Margin="0,0,8,0" />
            <Button Content="Pause" Width="90" Margin="0,0,8,0" />
            <Button Content="Stop" Width="90" />
        </StackPanel>

        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#666" CornerRadius="8" Padding="12">
            <TextBlock Text="MVP GUI scaffold готов. Логика будет добавлена в следующих задачах."
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="16" />
        </Border>
    </Grid>
</Window>
