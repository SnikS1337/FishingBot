<Window x:Class="FishingBot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FishingBot"
        Width="860" Height="620"
        MinWidth="860" MinHeight="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="BgDeep">#0D0F12</Color>
        <Color x:Key="BgPanel">#141720</Color>
        <Color x:Key="BgCard">#1C2030</Color>
        <Color x:Key="BgHover">#222840</Color>
        <Color x:Key="Accent">#00C9A7</Color>
        <Color x:Key="AccentDim">#00856E</Color>
        <Color x:Key="Danger">#FF4757</Color>
        <Color x:Key="TextPrimary">#E8ECF4</Color>
        <Color x:Key="TextSecondary">#6B7A99</Color>
        <Color x:Key="Border">#252D42</Color>

        <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeep}"/>
        <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDim}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="{StaticResource Border}"/>

        <!-- Toggle Style -->
        <Style x:Key="ToggleStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid VerticalAlignment="Center">
                            <Border x:Name="Track"
                                    Width="44" Height="24"
                                    CornerRadius="12"
                                    Background="#252D42"/>
                            <Ellipse x:Name="Thumb"
                                     Width="18" Height="18"
                                     Fill="{StaticResource TextSecondaryBrush}"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#0D0F12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDimBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Ghost Button -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <ContentPresenter x:Name="ContentSite"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="10,0,30,0"
                                                  VerticalAlignment="Center"/>
                                <Path Data="M 0 0 L 4 4 L 8 0"
                                      Stroke="{StaticResource TextSecondaryBrush}"
                                      StrokeThickness="1.5"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"/>
                                <ToggleButton Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Opacity="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Padding" Value="10,6"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgHover}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Slider Style -->
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="{StaticResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="#252D42"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="16" Height="16"
                                                         Fill="White"
                                                         Effect="{x:Null}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

    </Window.Resources>

    <!-- Root -->
    <Border CornerRadius="12"
            Background="{StaticResource BgDeepBrush}"
            BorderBrush="{StaticResource BorderBrush2}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <!-- Titlebar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ══════════════ TITLEBAR ══════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgPanelBrush}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Logo dot -->
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="FISHING"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13"
                                   FontWeight="Bold"
/>
                        <TextBlock Text="BOT"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="13"
                                   FontWeight="Bold"

                                   Margin="5,0,0,0"/>
                    </StackPanel>

                    <!-- Status badge -->
                    <Border x:Name="StatusBadge"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="4"
                            Padding="10,4"
                            Background="#1C2030">
                        <TextBlock x:Name="StatusText"
                                   Text="● ОСТАНОВЛЕН"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Click="MinimizeBtn_Click"
                                Width="32" Height="32"
                                ToolTip="Свернуть"
                                Style="{StaticResource GhostButton}"
                                Padding="0"
                                BorderThickness="0">
                            <Path Data="M 6 16 L 26 16"
                                  Stroke="{StaticResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"/>
                        </Button>
                        <Button Click="CloseBtn_Click"
                                Width="32" Height="32"
                                ToolTip="Закрыть"
                                Style="{StaticResource GhostButton}"
                                Padding="0"
                                BorderThickness="0"
                                Margin="4,0,0,0">
                            <Path Data="M 8 8 L 24 24 M 24 8 L 8 24"
                                  Stroke="{StaticResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════ MAIN CONTENT ══════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <!-- Left panel -->
                    <ColumnDefinition Width="*"/>
                    <!-- Right panel (preview + log) -->
                </Grid.ColumnDefinitions>

                <!-- ── LEFT PANEL ── -->
                <Border Grid.Column="0"
                        Background="{StaticResource BgPanelBrush}"
                        BorderBrush="{StaticResource BorderBrush2}"
                        BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel Margin="20,16,20,20">

                            <!-- ─ HOTKEYS ─ -->
                            <TextBlock Text="ГОРЯЧИЕ КЛАВИШИ"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"

                                       Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Запуск / Стоп"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                                <Border HorizontalAlignment="Right"
                                        Background="#252D42"
                                        CornerRadius="4"
                                        Padding="8,3">
                                    <TextBlock Text="F9"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Паник стоп"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                                <Border HorizontalAlignment="Right"
                                        Background="#2D1A1E"
                                        CornerRadius="4"
                                        Padding="8,3">
                                    <TextBlock Text="F10"
                                               Foreground="{StaticResource DangerBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,0,0,20"/>

                            <!-- ─ НАСТРОЙКИ ─ -->
                            <TextBlock Text="НАСТРОЙКИ"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"

                                       Margin="0,0,0,14"/>

                            <!-- Действие с рыбой -->
                            <TextBlock Text="Действие с рыбой"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="FishActionCombo"
                                      Style="{StaticResource DarkCombo}"
                                      Margin="0,0,0,16"
                                      ItemsSource="{Binding FishActions}"
                                      SelectedItem="{Binding SelectedFishAction}"/>

                            <!-- Авто перезаброс -->
                            <Grid Margin="0,0,0,14">
                                <TextBlock Text="Авто перезаброс"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                                <CheckBox HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Style="{StaticResource ToggleStyle}"
                                          IsChecked="{Binding AutoRecast}"/>
                            </Grid>

                            <!-- Задержка реакции -->
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Задержка реакции"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"/>
                                <TextBlock HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Text="{Binding ActionDelayMin, StringFormat={}{0} мс}"/>
                            </Grid>
                            <Slider Style="{StaticResource DarkSlider}"
                                    Minimum="50" Maximum="500"
                                    Value="{Binding ActionDelayMin}"
                                    Margin="0,0,0,16"/>

                            <!-- Задержка переброса -->
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Задержка переброса"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"/>
                                <TextBlock HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Text="{Binding RecastDelayMin, StringFormat={}{0} мс}"/>
                            </Grid>
                            <Slider Style="{StaticResource DarkSlider}"
                                    Minimum="500" Maximum="5000"
                                    Value="{Binding RecastDelayMin}"
                                    Margin="0,0,0,20"/>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,0,0,20"/>

                            <!-- ─ СОСТОЯНИЕ ─ -->
                            <TextBlock Text="СОСТОЯНИЕ"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"

                                       Margin="0,0,0,12"/>

                            <!-- FSM State -->
                            <Border Background="{StaticResource BgCardBrush}"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,8">
                                <Grid>
                                    <TextBlock Text="Фаза"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding CurrentState}"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Grid>
                            </Border>

                            <!-- Detection indicators -->
                            <Border Background="{StaticResource BgCardBrush}"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Прицел"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"/>
                                        <Ellipse Width="8" Height="8"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#252D42"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AimAligned}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Натяжение"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"/>
                                        <Ellipse Width="8" Height="8"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#252D42"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding BiteDetected}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Борьба"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"/>
                                        <Ellipse Width="8" Height="8"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#252D42"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FightDetected}" Value="True">
                                                            <Setter Property="Fill" Value="#FFB800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Меню поимки"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"/>
                                        <Ellipse Width="8" Height="8"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#252D42"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CatchMenuDetected}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Divider -->
                            <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,12,0,16"/>

                            <!-- ─ КНОПКИ УПРАВЛЕНИЯ ─ -->
                            <Button Content="▶  ЗАПУСТИТЬ"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding StartActiveCommand}"
                                    Height="38"
                                    Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="⏸ ПАУЗА"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding PauseResumeCommand}"
                                        Height="34"/>
                                <Button Grid.Column="2"
                                        Content="■  СТОП"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding StopCommand}"
                                        Height="34"/>
                            </Grid>

                            <Button Content="⚡  ДЕТЕКТ РЕЖИМ"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding StartDetectOnlyCommand}"
                                    Height="34"
                                    HorizontalAlignment="Stretch"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ── RIGHT PANEL ── -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- Preview -->
                        <RowDefinition Height="160"/>
                        <!-- Log -->
                    </Grid.RowDefinitions>

                    <!-- Preview -->
                    <Border Grid.Row="0" Background="{StaticResource BgDeepBrush}" Padding="16">
                        <Grid>
                            <Border Background="#0A0C0F"
                                    CornerRadius="8"
                                    BorderBrush="{StaticResource BorderBrush2}"
                                    BorderThickness="1">
                                <Grid>
                                    <!-- Placeholder -->
                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="📷"
                                                   FontSize="32"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Превью появится после запуска"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Live preview image -->
                                    <Image x:Name="PreviewImage"
                                           Source="{Binding LivePreview}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Grid>
                            </Border>

                            <!-- FPS badge -->
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,8,8,0"
                                    Background="#0D0F12CC"
                                    CornerRadius="4"
                                    Padding="8,3">
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10"
                                           Text="{Binding CaptureFps, StringFormat={}{0:F1} FPS}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Log -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BgPanelBrush}"
                            BorderBrush="{StaticResource BorderBrush2}"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Log header -->
                            <Border Grid.Row="0"
                                    Padding="16,0"
                                    BorderBrush="{StaticResource BorderBrush2}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="ЛОГ"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10"
                                               FontWeight="SemiBold"

                                               VerticalAlignment="Center"/>
                                    <Button Content="ОЧИСТИТЬ"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,3"
                                            BorderThickness="0"
                                            FontSize="10"
                                            Command="{Binding ClearLogsCommand}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Log list -->
                            <ListView Grid.Row="1"
                                      x:Name="LogList"
                                      ItemsSource="{Binding Logs}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="16,6"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      VirtualizingPanel.IsVirtualizing="True">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0,1"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   FontFamily="Consolas"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
