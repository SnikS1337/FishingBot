{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mode": {
    "build": {
      "permission": {
        "bash": {
          "ls*": "allow",
          "dotnet *": "allow",
          "bash .opencode/skills/task-management/router.sh *": "allow",
          "*": "deny"
        }
      }
    },
    "plan": {
      "permission": {
        "bash": {
          "ls*": "allow",
          "dotnet *": "allow",
          "bash .opencode/skills/task-management/router.sh *": "allow",
          "*": "deny"
        }
      }
    }
  },
  "agent": {
    "CoderAgent": {
      "permission": {
        "bash": "allow"
      }
    },
    "BuildAgent": {
      "permission": {
        "bash": "allow"
      }
    },
    "general": {
      "permission": {
        "bash": "allow"
      }
    }
  }
}
